{% for label, messages in app.flashes %}

	```
	{% for message in messages %}

		<div class="flash flash-{{ label }}">

			<span class="flash-message">
				{{ message }}
			</span>

			<button class="flash-close" onclick="this.parentElement.remove()">
				&times;
			</button>

		</div>

	{% endfor %}
	```

{% endfor %}
