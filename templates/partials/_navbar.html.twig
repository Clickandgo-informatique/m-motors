<div class="connection">
	{% if app.user %}
		<p class="connected">
			Vous êtes connecté en tant que
			{{ app.user.nickname }}
		</p>
		<a href="{{ path('app_logout') }}">Se déconnecter</a>
	{% else %}
		<p class="not-connected">Vous n'êtes pas encore connecté.e</p>
		<a href="{{ path('app_login') }}">Se connecter</a>
		<a href="{{ path('app_register') }}">S'inscrire</a>
	{% endif %}
</div>

<div class="navbar-links">
	<ul>
		<li>
			<a href="{{ path('app_home') }}" class="{{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}">
				Accueil
			</a>
		</li>

		<li>
			<a href="#" class="{{ app.request.attributes.get('_route') == 'app_about' ? 'active' : '' }}">
				À propos
			</a>
		</li>

		<li>
			<a href="#" class="{{ app.request.attributes.get('_route') == 'app_contact' ? 'active' : '' }}">
				Contact
			</a>
		</li>

		{% if not app.user %}
			<li>
				<a href="{{ path('app_login') }}" class="{{ app.request.attributes.get('_route') == 'app_login' ? 'active' : '' }}">
					Connexion
				</a>
			</li>
		{% endif %}
	</ul>
</div>
